--- a/utils/pdf_generator.py
+++ b/utils/pdf_generator.py
@@ -1,6 +1,24 @@
 from fpdf import FPDF
 import os
-import together
+import together
+
+together.api_key = os.getenv("TOGETHER_API_KEY", "").strip()
+
+def call_together(prompt, max_tokens=300):
+    try:
+        resp = together.Complete.create(
+            prompt=prompt,
+            model="togethercomputer/llama-2-70b-chat",
+            max_tokens=max_tokens,
+            temperature=0.7,
+        )
+        return resp['output']['choices'][0]['text'].strip()
+    except Exception as e:
+        print(f"Together.ai error: {e}")
+        return ""
+
-def generate_dynamic_pdf(topic="digital marketing"):
+def generate_dynamic_pdf(topic="digital marketing", filename="content_pack.pdf"):
+    print(f"Generating PDF for topic: {topic}")
     blog = call_together(f"Write a 300-word blog post about {topic}.")
     caps = call_together(f"Write 3 social media captions about {topic}.")
     lead = call_together(f"Suggest a lead magnet idea for {topic}.")
     kw = call_together(f"List 5 SEO keywords for {topic}, comma separated.")
+
+    pdf = FPDF()
+    pdf.add_page()
+    pdf.set_font("Arial", size=12)
+    pdf.cell(200, 10, txt="AI Content Pack", ln=True, align="C")
+    pdf.ln(10)
+    for title, content in [("Blog:", blog), ("Captions:", caps), ("Lead Magnet:", lead), ("Keywords:", kw)]:
+        pdf.multi_cell(0, 10, f"{title}\n{content}")
+
+    path = f"./{filename}"
+    pdf.output(path)
+    return path
